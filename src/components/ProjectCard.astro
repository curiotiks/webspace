---
import type { Project } from "../data/projects";

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<article class="card group h-full overflow-hidden p-6 transition-transform duration-200 hover:-translate-y-1">
  <div class="mb-4 flex flex-wrap gap-2">
    <span class="tag">{project.status}</span>
    <span class="tag">{project.timeframe}</span>
  </div>
  <h3 class="mb-3 text-xl font-semibold text-slate-100">
    <a href={`/projects/${project.slug}/`} class="transition-colors group-hover:text-cyan-300">
      {project.title}
    </a>
  </h3>
  <p class="text-sm leading-6 text-slate-400">{project.summary}</p>
</article>
