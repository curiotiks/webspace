---
import { Image } from 'astro:assets';
import SocialIcons from './SocialIcons.astro';
import portraitImage from '../assets/portrait/IMG_0909.JPG';
const { name, tagline, twitter, linkedin, github, scholar, orcid, email } = Astro.props;
---

<section class="hero">
  <div class="hero-content">
    <div class="portrait-container">
      <Image src={portraitImage} alt={name} class="portrait" />
    </div>
    <div class="hero-text">
      <h1>{name}</h1>
      <p class="tagline">{tagline}</p>
      <SocialIcons 
        size={40}
        gap=1.5
        twitter={twitter} 
        linkedin={linkedin} 
        github={github}
        scholar={scholar} 
        orcid={orcid}
        email={email} 
      />
    </div>
  </div>
</section>
