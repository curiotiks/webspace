---
import Layout from '../layouts/Layout.astro';
import { SITE_DATA } from '../constants';

import '../styles/contact.css';

const contactProfiles = [
    {
        label: 'GitHub',
        href: `https://github.com/${SITE_DATA.github}`,
        note: 'Best for code, projects, and public-facing collaboration.',
    },
    {
        label: 'LinkedIn',
        href: SITE_DATA.linkedin,
        note: 'Best for professional outreach, teaching, and consulting conversations.',
    },
    {
        label: 'Bluesky',
        href: `https://bsky.app/profile/${SITE_DATA.bluesky}`,
        note: 'A lighter-weight public channel for staying in touch.',
    },
].filter((profile) => profile.href);
---

<Layout pageTitle="Contact">
    <span class="eyebrow">Contact</span>
    <h1>Get in Touch</h1>
    <p class="page-intro">
        I keep my direct email address off the site. For research, collaboration, teaching, or consulting questions,
        reach out through one of the public profiles below.
    </p>

    <div class="contact-links">
        {contactProfiles.map((profile) => (
            <a href={profile.href} class="contact-link" target="_blank" rel="noopener noreferrer">
                <span class="contact-link-label">{profile.label}</span>
                <span class="contact-link-note">{profile.note}</span>
            </a>
        ))}
    </div>
</Layout>
