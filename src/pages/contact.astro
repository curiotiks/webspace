---
import Layout from '../layouts/Layout.astro';
import { CONTACT_FORM_ENDPOINT } from '../constants';

import '../styles/contact.css';

const formConfigured = CONTACT_FORM_ENDPOINT.length > 0;
---

<Layout pageTitle="Contact">
    <span class="eyebrow">Contact</span>
    <h1>Get in Touch</h1>
    <p class="page-intro">
        Use the form below for research, teaching, collaboration, or consulting enquiries. The site does not display a
        raw email address directly.
    </p>

    {!formConfigured && (
        <div class="card note-card">
            <p>This form is wired for a static endpoint but is not active yet.</p>
            <p>Set <code>PUBLIC_CONTACT_FORM_ENDPOINT</code> in Render to your Formspree endpoint to turn delivery on.</p>
        </div>
    )}

    <section class="card contact-panel">
        <form
            class="form-grid"
            method="POST"
            action={formConfigured ? CONTACT_FORM_ENDPOINT : '#'}
            data-configured={formConfigured ? 'true' : 'false'}
        >
            {formConfigured && <input type="hidden" name="_subject" value="Website contact form submission" />}

            <label>
                Name
                <input type="text" name="name" autocomplete="name" required />
            </label>

            <label>
                Email
                <input type="email" name="email" autocomplete="email" required />
            </label>

            <label>
                Subject
                <input type="text" name="subject" autocomplete="off" required />
            </label>

            <label>
                Message
                <textarea name="message" rows="8" required></textarea>
            </label>

            <button type="submit" class="btn contact-submit" disabled={!formConfigured}>Send message</button>
        </form>
    </section>
</Layout>

<script>
    const contactForm = document.querySelector('form[data-configured]');

    if (contactForm?.getAttribute('data-configured') !== 'true') {
        contactForm?.addEventListener('submit', (event) => {
            event.preventDefault();
        });
    }
</script>
