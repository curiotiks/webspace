---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact" description="Contact for consultation, collaboration, and research.">
  <div class="page-container">
    <h1>Contact</h1>

    <section>
      <h2>Get in touch</h2>
      <div class="contact-card">
        <p>
          This route is intended to collect enquiries without exposing personal email addresses across the site.
          The form below is a front-end placeholder and should be connected to a mail relay or hosted form service.
        </p>
      </div>
    </section>

    <section>
      <h2>Inquiry form</h2>
      <form class="form-grid">
        <label>
          Name
          <input type="text" name="name" autocomplete="name" />
        </label>
        <label>
          Email
          <input type="email" name="email" autocomplete="email" />
        </label>
        <label>
          Message
          <textarea name="message" rows="8"></textarea>
        </label>
        <div class="button-row">
          <button class="button-primary" type="submit">Send inquiry</button>
        </div>
      </form>
    </section>
  </div>
</BaseLayout>
