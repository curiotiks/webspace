---
import Layout from '../layouts/Layout.astro';
import { PROJECTS } from '../data/projects';
import { url } from '../utils/paths';

import '../styles/projects.css';
---

<Layout pageTitle="Projects">
    <div class="projects-hero">
        <span class="eyebrow">Projects</span>
        <h1>Research and Applied Work</h1>
        <p class="page-intro">
            Current work across game-based assessment, measurement, research workflows, and data literacy design.
        </p>
    </div>

    <div class="projects-grid">
        {PROJECTS.map((project) => (
            <article class="project-card">
                <div class={`project-image project-image--${project.id}`}>
                    <span class="project-wordmark">{project.visualLabel}</span>
                    <span class="status-badge project-badge">{project.status}</span>
                </div>

                <div class="project-content">
                    <div class="meta-line">{project.year}</div>
                    <h2 class="project-title">
                        <a href={url(`/projects/${project.id}`)}>{project.title}</a>
                    </h2>
                    <p>{project.description}</p>

                    <a href={url(`/projects/${project.id}`)} class="text-button">View project</a>
                </div>
            </article>
        ))}
    </div>
</Layout>
