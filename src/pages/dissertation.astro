---
import fs from 'node:fs';
import path from 'node:path';
import Layout from '../layouts/Layout.astro';
import { DISSERTATION_SLIDES_URL } from '../constants';
import { DISSERTATION } from '../data/profile';

import '../styles/dissertation.css';

const base = import.meta.env.BASE_URL;

const publicRoot = path.join(process.cwd(), 'public');
const documentDir = path.join(publicRoot, 'files', 'dissertation');
const videoDir = path.join(publicRoot, 'media', 'dissertation');

const findFirstFile = (dir: string, extensions: string[]) => {
    if (!fs.existsSync(dir)) return null;

    return fs.readdirSync(dir).find((file) => {
        const ext = path.extname(file).toLowerCase();
        return extensions.includes(ext);
    }) ?? null;
};

const dissertationPdf = findFirstFile(documentDir, ['.pdf']);
const recordingVideo = findFirstFile(videoDir, ['.mp4', '.webm', '.mov', '.m4v']);

const pdfUrl = dissertationPdf ? `${base}files/dissertation/${encodeURIComponent(dissertationPdf)}` : null;
const videoUrl = recordingVideo ? `${base}media/dissertation/${encodeURIComponent(recordingVideo)}` : null;

const videoMimeTypes: Record<string, string> = {
    '.mp4': 'video/mp4',
    '.webm': 'video/webm',
    '.mov': 'video/quicktime',
    '.m4v': 'video/x-m4v',
};

const videoMimeType = recordingVideo ? videoMimeTypes[path.extname(recordingVideo).toLowerCase()] : null;
---

<Layout pageTitle="Dissertation">
    <span class="eyebrow">Dissertation</span>
    <h1>{DISSERTATION.title}</h1>
    <p class="page-intro">{DISSERTATION.summary}</p>

    <section>
        <h2>Video Recording</h2>

        {videoUrl && videoMimeType ? (
            <video controls preload="metadata" class="dissertation-video">
                <source src={videoUrl} type={videoMimeType} />
                Your browser does not support the embedded video player.
            </video>
        ) : (
            <div class="card note-card">
                <p>The recording is not uploaded yet.</p>
                <p>
                    Add an <code>.mp4</code>, <code>.webm</code>, <code>.mov</code>, or <code>.m4v</code> file to
                    <code> public/media/dissertation/</code> and it will appear here automatically.
                </p>
            </div>
        )}
    </section>

    <section>
        <h2>Materials</h2>

        {pdfUrl ? (
            <div class="action-row">
                <a href={pdfUrl} class="btn" target="_blank" rel="noopener noreferrer">Open dissertation PDF</a>
                <a href={pdfUrl} class="btn-outline" download>Download dissertation PDF</a>
                <a href={DISSERTATION_SLIDES_URL} class="btn-outline" target="_blank" rel="noopener noreferrer">View defense slides</a>
            </div>
        ) : (
            <div class="card note-card">
                <p>No dissertation PDF is in place yet.</p>
                <p>
                    Add the file to <code>public/files/dissertation/</code>. The page will automatically use the first
                    PDF it finds there.
                </p>
            </div>
        )}
    </section>

    {pdfUrl && (
        <section>
            <h2>Read Online</h2>
            <iframe src={pdfUrl} title="Dissertation PDF" class="dissertation-document"></iframe>
        </section>
    )}

    <section>
        <h2>Supplemental Materials</h2>
        <div class="card note-card">
            <p>
                This section is reserved for additional artifacts, appendices, handouts, datasets, and related
                materials as they are prepared for release.
            </p>
        </div>
    </section>
</Layout>
