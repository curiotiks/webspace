---
import Layout from '../layouts/Layout.astro';
---

<Layout pageTitle="404">
	<span class="eyebrow">404</span>
	<h1>Page Not Found</h1>
	<p class="page-intro">The page you were trying to reach does not exist.</p>
	<div class="action-row">
		<a href={import.meta.env.BASE_URL} class="btn">Return home</a>
	</div>
</Layout>
