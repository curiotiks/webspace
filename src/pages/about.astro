---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import portraitImage from '../assets/portrait/IMG_0909.JPG';
import chinaImage from '../assets/site/DSC03689.JPG';
import landscapeImage from '../assets/site/IMG_0037.JPG';
import skyImage from '../assets/site/IMG_5393.jpeg';
import { ABOUT_SECTIONS, CURRENT_GOALS, PROFILE, RESEARCH_AREAS } from '../data/profile';

import '../styles/about.css';
---

<Layout pageTitle="About" description={PROFILE.description}>
    <section class="about-hero">
        <div>
            <span class="eyebrow">About</span>
            <h1>Background and Direction</h1>
            <p class="page-intro">{PROFILE.intro}</p>
            <ul class="tag-list">
                {RESEARCH_AREAS.map((area) => (
                    <li>{area}</li>
                ))}
            </ul>
        </div>

        <Image src={portraitImage} alt="Portrait of G. Curt Fulwider" class="about-portrait" />
    </section>

    <section class="about-gallery">
        <Image src={chinaImage} alt="Architectural scene photographed in China" class="gallery-primary" />
        <Image src={landscapeImage} alt="Landscape photograph" class="gallery-secondary" />
        <Image src={skyImage} alt="Skyline and lamppost photograph" class="gallery-secondary" />
    </section>

    {ABOUT_SECTIONS.map((section) => (
        <section class="about-section">
            <h2>{section.title}</h2>
            {section.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
        </section>
    ))}

    <section class="about-section">
        <h2>Current Priorities</h2>
        <ul class="simple-list">
            {CURRENT_GOALS.map((goal) => (
                <li>{goal}</li>
            ))}
        </ul>
    </section>
</Layout>
