---
import Layout from '../layouts/Layout.astro';
import { PRESENTATION_SECTIONS } from '../data/presentations';
---

<Layout pageTitle="Presentations">
    <div class="page-container">
        <h1>Presentations</h1>

        <p class="intro-text">
            Selected conference papers, posters, and invited teaching-facing talks drawn from my current academic
            work in learning sciences, educational data science, and interactive assessment.
        </p>

        {PRESENTATION_SECTIONS.map((section) => (
            <section>
                <h2>{section.title}</h2>
                <ul class="custom-list">
                    {section.items.map((item) => (
                        <li>
                            {item.link ? (
                                <a class="list-item-title" href={item.link} target="_blank" rel="noopener noreferrer">
                                    {item.title}
                                </a>
                            ) : (
                                <span class="list-item-title">{item.title}</span>
                            )}
                            <span class="list-item-description">
                                {item.authors}. {item.venue}
                                {item.detail && <span class="extra-links">{item.detail}</span>}
                            </span>
                        </li>
                    ))}
                </ul>
            </section>
        ))}
    </div>
</Layout>
