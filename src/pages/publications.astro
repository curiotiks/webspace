---
import Layout from '../layouts/Layout.astro';
import publicationsData from '../data/publications.json';
import { GOOGLE_SCHOLAR_URL, SITE_DATA } from '../constants';

import '../styles/publications.css';

const selectedPublications = publicationsData.filter((pub) => pub.publicationType !== 'Poster');
---

<Layout pageTitle="Publications">
    <span class="eyebrow">Publications</span>
    <h1>Select Publications</h1>
    <p class="page-intro">
        Selected peer-reviewed publications and conference papers. Presentation listings are intentionally left to
        ORCID and Google Scholar.
    </p>

    <div class="action-row">
        <a href={`https://orcid.org/${SITE_DATA.orcid}`} class="btn" target="_blank" rel="noopener noreferrer">ORCID</a>
        <a href={GOOGLE_SCHOLAR_URL} class="btn-outline" target="_blank" rel="noopener noreferrer">Google Scholar</a>
    </div>

    <ol class="publication-list publications-page-list">
        {selectedPublications.map((pub) => (
            <li>
                {pub.link ? (
                    <a class="publication-title" href={pub.link} target="_blank" rel="noopener noreferrer">{pub.title}</a>
                ) : (
                    <span class="publication-title">{pub.title}</span>
                )}
                <div class="meta-line">{pub.authors}</div>
                <div class="meta-line">{pub.journal} · {pub.year} · {pub.publicationType}</div>
            </li>
        ))}
    </ol>
</Layout>
