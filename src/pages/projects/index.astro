---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { projects } from '../../data/projects';
---

<BaseLayout title="Projects" description="Current and past project pages.">
  <div class="page-container">
    <h1>Projects</h1>
    <p class="page-lead">
      Current and archival work across interactive assessment systems, dashboards, and gameplay analytics.
    </p>

    <section>
      <h2>Current and past work</h2>
      <div class="card-grid">
        {projects.map((project) => (
          <article class="project-card">
            <h3><a href={`${import.meta.env.BASE_URL}projects/${project.slug}/`}>{project.title}</a></h3>
            <p style="margin: 0.4rem 0 0.75rem 0;">{project.summary}</p>
            <div class="chip-list">
              <span class="tag">{project.status}</span>
              <span class="tag">{project.timeframe}</span>
            </div>
          </article>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>
