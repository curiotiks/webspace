---
import BaseLayout from '../layouts/BaseLayout.astro';
import { profile } from '../data/profile';
---

<BaseLayout title="Consulting" description={profile.consulting.summary} noindex={true}>
  <div class="page-container">
    <h1>{profile.consulting.title}</h1>

    <section>
      <h2>Status</h2>
      <div class="info-card">
        <p>{profile.consulting.status}</p>
      </div>
    </section>

    <section>
      <h2>Scope</h2>
      <div class="info-card">
        <p>
          {profile.consulting.summary} This page is intentionally live but not linked in the main navigation yet.
          It can expand into consulting offers around educational data analysis, dashboarding, reporting workflows,
          measurement, and research support.
        </p>
      </div>
    </section>
  </div>
</BaseLayout>
